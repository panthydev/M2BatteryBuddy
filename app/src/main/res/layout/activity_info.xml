<?xml version="1.0" encoding="utf-8"?>
<!-- start of layout -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InfoActivity"

    >

    <include layout="@layout/buttom_bar"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:scaleX="-1"
            android:scaleY="-1"
            app:srcCompat="@drawable/bottom_bar_bg" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- This is the base cardview-->
                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Information on Digital maintenance"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textSize="30sp"
                    android:textStyle="bold|italic" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/base_cardview"
                    style="@style/Base.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="20dp">

                    <!-- This is a ConstraintLayout for the entire CardView including the expandable portion -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/purple_light"
                        app:layout_constraintBottom_toBottomOf="@+id/base_cardview"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.511"
                        tools:layout_editor_absoluteX="-55dp">

                        <!-- This is a ConstraintLayout for the fixed portion of the CardView. The elements that
            lie within the fixed portion of the CardView can be constrained to this layout -->

                        <!-- The following is the expandable portion whose visibility is initially set to 'gone'
            The parent LinearLayout contains 3 child LinearLayouts that hold a subject name and an icon each -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/fixed_layout"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            app:layout_constraintTop_toTopOf="parent">


                            <!-- This is the Header textview -->
                            <TextView
                                android:id="@+id/heading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:layout_marginEnd="175dp"
                                android:alpha="0.7"
                                android:text="Header"
                                android:textColor="@color/white"
                                android:textSize="25sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/arrow_button"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!--This is the textview for the undertitle-->
                            <TextView
                                android:id="@+id/list_of_subjects"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="65dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="175dp"
                                android:layout_marginBottom="19dp"
                                android:alpha="0.7"
                                android:text="Undertitle"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/arrow_button"
                                app:layout_constraintTop_toBottomOf="@+id/heading" />

                            <!--This is the orange image button, any image can be used but the one chosen here works well.
                        To get the rounded corners see @drawable/roundcorners for the xml file which does this-->
                            <ImageButton
                                android:id="@+id/arrow_button"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="16dp"
                                android:layout_marginTop="27dp"
                                android:layout_marginEnd="65dp"
                                android:layout_marginBottom="30dp"
                                android:background="@drawable/roundcorners"
                                android:src="@drawable/outline_arrow_circle_right_24"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/heading"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!--This is the Hidden view which needs to start off as gone for it to be hidden-->
                        <LinearLayout
                            android:id="@+id/hidden_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            app:layout_constraintTop_toBottomOf="@+id/fixed_layout">

                            <!--This is the textview which is desplayed within the hidden view-->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="20dp"
                                android:layout_marginTop="20dp"
                                android:text="@string/longLoremIpsum"
                                android:textColor="@color/white"
                                android:textSize="20sp" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>